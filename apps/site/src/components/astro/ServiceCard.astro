---
interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  imageUrl: string;
  price?: string;
}

const { slug, title, description, category, imageUrl, price } = Astro.props;
---

<a
  href={`/services/${slug}`}
  class="group block overflow-hidden rounded-xl border border-border bg-card transition-shadow hover:shadow-lg"
>
  <div class="aspect-[3/2] overflow-hidden bg-muted">
    <img
      src={imageUrl}
      alt={title}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <div class="p-5">
    <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
      {category}
    </span>
    <h3 class="mt-1 text-base font-semibold text-foreground">{title}</h3>
    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted-foreground">
      {description}
    </p>
    {price && (
      <p class="mt-3 text-sm font-medium text-foreground">{price}</p>
    )}
  </div>
</a>
