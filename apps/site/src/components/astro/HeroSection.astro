---
import { Button, Container } from "../ui";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Services built for modern teams",
  subtitle = "We combine deep expertise with thoughtful execution to deliver outcomes that compound.",
} = Astro.props;
---

<section class="relative overflow-hidden bg-background">
  <Container className="pb-24 pt-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground/80">
        LabQ Storefront
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl text-wrap: balance"
      >
        {title}
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground text-wrap: pretty">
        {subtitle}
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <Button href="/services" variant="primary">
          Browse Services
        </Button>
        <Button href="#featured" variant="outline">
          See Featured Work
        </Button>
      </div>
    </div>
  </Container>
</section>
