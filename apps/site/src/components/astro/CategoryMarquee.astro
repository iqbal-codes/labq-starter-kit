---
import { fetchCategories } from "../../data";

const categories = await fetchCategories();
---

{
  categories.length > 0 && (
    <section class="py-12">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-center gap-3">
          {categories.map((category) => (
            <a
              href={`/services#${category.slug}`}
              class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
            >
              {category.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
