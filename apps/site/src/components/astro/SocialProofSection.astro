---
import { socialProofStats, testimonials } from "../../data";
---

<section class="bg-muted/40 py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Trusted by teams that ship
      </h2>
      <p class="mt-2 text-lg text-muted-foreground">
        Strategy, execution, and measurable outcomes — all in one partnership.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {socialProofStats.map((stat) => (
        <div class="rounded-2xl border border-border bg-background/70 p-5 text-center">
          <p class="text-2xl font-semibold tracking-tight text-foreground">{stat.value}</p>
          <p class="mt-2 text-sm text-muted-foreground">{stat.label}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <figure class="rounded-xl border border-border bg-card p-8">
          <blockquote class="text-sm leading-relaxed text-muted-foreground">
            &ldquo;{testimonial.quote}&rdquo;
          </blockquote>
          <figcaption class="mt-6 flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-muted text-xs font-semibold text-muted-foreground">
              {testimonial.name.split(" ").map((part) => part[0]).join("")}
            </div>
            <div>
              <p class="text-sm font-medium text-foreground">{testimonial.name}</p>
              <p class="text-xs text-muted-foreground">{testimonial.role}</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
