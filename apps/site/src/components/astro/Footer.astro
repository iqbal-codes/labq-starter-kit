---
import { NewsletterForm } from "../islands/index.ts";
import { Container } from "../ui";

const year = new Date().getFullYear();

const footerLinks = [
  {
    heading: "Services",
    links: [
      { href: "/services", label: "All Services" },
      { href: "/services#consulting", label: "Consulting" },
      { href: "/services#analytics", label: "Analytics" },
    ],
  },
  {
    heading: "Company",
    links: [
      { href: "/contact", label: "Contact" },
      { href: "/services", label: "How we work" },
      { href: "/services#consulting", label: "Discovery call" },
    ],
  },
  {
    heading: "Legal",
    links: [
      { href: "/contact", label: "Privacy" },
      { href: "/contact", label: "Terms" },
    ],
  },
];
---

<footer class="border-t border-border bg-muted/40">
  <Container className="py-16">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="text-lg font-semibold tracking-tight text-foreground">
          LabQ
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-muted-foreground">
          Professional services and analytics, delivered with precision and care.
        </p>
        <div class="mt-6">
          <h3 class="text-sm font-semibold text-foreground">Stay in the loop</h3>
          <p class="mt-2 text-sm text-muted-foreground">
            Tips, updates, and insights — delivered monthly.
          </p>
          <div class="mt-3">
            <NewsletterForm client:idle />
          </div>
        </div>
      </div>

      <!-- Link columns -->
      {footerLinks.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-foreground">{group.heading}</h3>
          <ul class="mt-4 space-y-3">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-border pt-8 sm:flex-row">
      <p class="text-xs text-muted-foreground">
        &copy; {year} LabQ. All rights reserved.
      </p>
    </div>
  </Container>
</footer>
