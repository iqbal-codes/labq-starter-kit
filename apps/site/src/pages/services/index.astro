---
import StorefrontLayout from "../../layouts/StorefrontLayout.astro";
import Breadcrumb from "../../components/astro/Breadcrumb.astro";
import ServiceCard from "../../components/astro/ServiceCard.astro";
import CtaBand from "../../components/astro/CtaBand.astro";
import { fetchServicesByCategory } from "../../data";
import { formatPrice } from "../../lib";

const categorySections = await fetchServicesByCategory();
---

<StorefrontLayout
  title="Services — LabQ"
  description="Browse our full catalog of professional services."
>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <Breadcrumb items={[{ label: "Services", href: "/services" }]} />

      <div class="mt-8 max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-foreground">
          Services built for modern teams
        </h1>
        <p class="mt-3 text-lg leading-relaxed text-muted-foreground">
          Browse our consulting, analytics, and product delivery engagements.
          Each offer is designed to move from clarity to execution without
          unnecessary overhead.
        </p>
      </div>

      {
        categorySections.length === 0 ? (
          <div class="mt-12 rounded-3xl border border-border bg-card p-8 text-center">
            <h2 class="text-2xl font-semibold text-foreground">
              No services available right now
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Check back soon, or get in touch to discuss a custom engagement.
            </p>
            <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
              <a
                href="/contact#contact-form"
                class="inline-flex h-11 items-center rounded-4xl bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80"
              >
                Contact us
              </a>
              <a
                href="/"
                class="inline-flex h-11 items-center rounded-4xl border border-border px-6 text-sm font-medium text-foreground transition-colors hover:bg-muted"
              >
                Back to home
              </a>
            </div>
          </div>
        ) : (
          <>
            <div class="mt-10 flex flex-wrap gap-2">
              {categorySections.map((category) => (
                <a
                  href={`#${category.slug}`}
                  class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-medium text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
                >
                  {category.label}
                </a>
              ))}
            </div>

            <div class="mt-14 space-y-14">
              {categorySections.map((category) => (
                <section id={category.slug} class="scroll-mt-24">
                  <div class="mb-6">
                    <h2 class="text-2xl font-semibold tracking-tight text-foreground">
                      {category.label}
                    </h2>
                    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                      Focused engagements for teams that want momentum, not noise.
                    </p>
                  </div>

                  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {category.services.map((service) => (
                      <ServiceCard
                        slug={service.slug}
                        title={service.title}
                        description={service.description}
                        category={service.category}
                        imageUrl={service.imageUrl}
                        price={
                          service.priceCents === null
                            ? undefined
                            : `From ${formatPrice(service.priceCents)}`
                        }
                      />
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </>
        )
      }
    </div>
  </section>

  <CtaBand
    title="Need a custom engagement?"
    subtitle="Book a strategy call and we’ll shape the right scope together."
  />
</StorefrontLayout>
