---
import StorefrontLayout from "../layouts/StorefrontLayout.astro";
import Breadcrumb from "../components/astro/Breadcrumb.astro";
import { CheckoutSummary } from "../components/islands/index.ts";
---

<StorefrontLayout
  title="Checkout — LabQ"
  description="Review your selected services and continue to a concierge-led checkout flow."
>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <Breadcrumb items={[{ label: "Checkout", href: "/checkout" }]} />

      <div class="mt-8 grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-muted-foreground">
            Checkout
          </p>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
            Review your request before we finalize the engagement.
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">
            This storefront is set up for a concierge-led commerce flow today. You can
            still build a cart, review your estimated subtotal, and continue into a
            contact handoff while the public checkout API is being wired.
          </p>
        </div>

        <CheckoutSummary client:load />
      </div>
    </div>
  </section>
</StorefrontLayout>
