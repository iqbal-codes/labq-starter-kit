# ===========================================
# Admin App Template — Single-App Internal Tools Platform
# ===========================================
# Copy this file to .env and update the values.

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admin_app_template_dev
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=admin_app_template_dev
POSTGRES_PORT=5432
POSTGRES_CONTAINER=postgres-local
POSTGRES_ADMIN_DB=postgres

# ===========================================
# Better Auth
# ===========================================
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3100
STOREFRONT_SITE_ORIGIN=http://localhost:3200

# ===========================================
# OAuth (Optional)
# ===========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# App Settings
# ===========================================
NODE_ENV=development

# ===========================================
# Frontend Environment Variables
# ===========================================
VITE_API_URL=http://localhost:4000
PUBLIC_API_BASE=http://localhost:4000
PUBLIC_ORG_SLUG=

# ===========================================
# S3-Compatible Object Storage (MinIO local / R2 prod)
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=admin-app-template-dev
S3_FORCE_PATH_STYLE=true
S3_MAX_UPLOAD_BYTES=26214400
S3_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,application/pdf,text/plain,text/csv,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ===========================================
# Email delivery (optional, required for real public contact submission)
# ===========================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ===========================================
# Email / Contact Inquiry
# ===========================================
# Where public contact form inquiries are delivered.
# Falls back to RESEND_FROM_EMAIL if not set.
CONTACT_EMAIL=
